<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:padding="24dp">

    <!-- Graphic Container -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardGraphic"
        android:layout_width="0dp"
        android:layout_height="320dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/stroke_color"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/graphicContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">
            <!-- Graphics will be injected here or handled by visibility in code -->
            
            <!-- Step 1 Graphic (Simplified) -->
            <LinearLayout
                android:id="@+id/step1Graphic"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    app:cardBackgroundColor="@color/icon_bg_purple"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="24dp">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center"
                        android:src="@drawable/app_logo"
                        android:contentDescription="@string/app_name" />
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Display Over Apps"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Step 2 Graphic (Simplified Selection) -->
            <RelativeLayout
                android:id="@+id/step2Graphic"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">
                 <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="20dp"
                    android:background="@drawable/bg_dashed_stroke" />
                 <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentEnd="true"
                    android:src="@android:drawable/stat_notify_chat"
                    app:tint="@color/text_accent_blue" />
            </RelativeLayout>

            <!-- Step 3 Graphic (Simplified Chat) -->
            <LinearLayout
                android:id="@+id/step3Graphic"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/icon_bg_purple"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="&quot;Where is the nearest station?&quot;"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/text_accent_blue"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="「最寄りの駅はどこですか？」"
                        android:textColor="@color/white" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvFlowLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ONBOARDING FLOW"
        android:textColor="@color/text_accent_purple"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/cardGraphic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvStepTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 1: Enable\nBridge."
        android:textColor="@color/text_primary"
        android:textSize="36sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvFlowLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvStepDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Allow Bridge to float over other apps for instant translation."
        android:textColor="@color/text_secondary"
        android:textSize="17sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvStepTitle" />

</androidx.constraintlayout.widget.ConstraintLayout>
